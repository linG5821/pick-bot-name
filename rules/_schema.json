{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "name", "algorithm", "style", "languages", "data", "author"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "规则唯一标识，格式: {style}-{language}-{variant}"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "版本号"
    },
    "name": {
      "type": "object",
      "required": ["en", "zh"],
      "properties": {
        "en": { "type": "string" },
        "zh": { "type": "string" },
        "ja": { "type": "string" }
      },
      "description": "规则名称（多语言）"
    },
    "description": {
      "type": "object",
      "properties": {
        "en": { "type": "string" },
        "zh": { "type": "string" },
        "ja": { "type": "string" }
      },
      "description": "规则描述"
    },
    "style": {
      "type": "string",
      "enum": ["cyberpunk", "cute", "professional", "geek", "fantasy", "minimal", "steampunk", "anime", "military", "nature"],
      "description": "所属风格"
    },
    "languages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["en", "zh", "ja", "ko", "fr", "de"]
      },
      "description": "支持的语言"
    },
    "algorithm": {
      "enum": ["combination", "template", "markov", "syllable"],
      "description": "生成算法"
    },
    "platformOptimized": {
      "type": "array",
      "items": { "type": "string" },
      "description": "优化的平台列表（可选）"
    },
    "author": {
      "type": "object",
      "required": ["name", "github"],
      "properties": {
        "name": { "type": "string" },
        "github": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "description": "作者信息"
    },
    "license": {
      "type": "string",
      "description": "许可证"
    },
    "data": {
      "type": "object",
      "description": "生成数据（根据algorithm不同而不同）"
    },
    "examples": {
      "type": "array",
      "items": { "type": "string" },
      "description": "示例名称"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "标签"
    }
  }
}
